# Copy this to .env and fill in your values

# App
ENVIRONMENT=development
DEBUG=true

# Security — CHANGE THIS IN PRODUCTION
SECRET_KEY=super-secret-change-in-production
ADMIN_PASSWORD=changeme

# Database (leave blank to use SQLite in dev mode)
# DATABASE_URL=postgresql+asyncpg://ntth_user:changeme@localhost:5432/ntth

# Network
NETWORK_INTERFACE=eth0
GATEWAY_IP=192.168.1.1

# GeoIP (download GeoLite2 from maxmind.com)
# GEOIP_DB_PATH=./geoip/GeoLite2-City.mmdb
# GEOIP_ASN_DB_PATH=./geoip/GeoLite2-ASN.mmdb

# PostgreSQL (Docker)
POSTGRES_DB=ntth
POSTGRES_USER=ntth_user
POSTGRES_PASSWORD=changeme

# Cowrie honeypot
COWRIE_CONTAINER_NAME=ntth_cowrie
